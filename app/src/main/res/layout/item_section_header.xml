<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingTop="24dp"
    android:paddingBottom="10dp"
    android:gravity="center_vertical">

    <TextView android:id="@+id/txtSectionTitle"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="20sp" android:textStyle="bold"
        android:textColor="@color/text_main" android:fontFamily="sans-serif-black"/>

    <TextView android:id="@+id/txtSectionSub"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="13sp" android:textColor="@color/terra" android:textStyle="bold"/>
</LinearLayout>
