<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp">

        <ImageView android:id="@+id/imgPerson"
            android:layout_width="54dp" android:layout_height="54dp"
            android:scaleType="centerCrop" android:background="@color/surface"
            android:layout_marginEnd="12dp"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/txtPersonName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_main"/>
            <TextView android:id="@+id/txtPersonRole"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <TextView android:id="@+id/txtPersonPoop"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textStyle="bold" android:textColor="@color/poop_light"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
